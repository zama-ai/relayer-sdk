{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Hello Test",
      "type": "node",
      "runtimeVersion": "22",
      "request": "launch",
      "runtimeArgs": [
        "--test",
        "--import",
        "tsx",
        "${workspaceFolder}/src/index.hello.test.ts"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Debug Client Decrypt Test",
      "type": "node",
      "runtimeVersion": "22",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/.bin/vitest",
      "args": [
        "run",
        "--config",
        "test/fheTest/vitest.config.ts",
        "ethers/clientDecrypt.debugPayload"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
